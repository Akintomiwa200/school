{
  "expo": {
    "name": "School LMS",
    "slug": "school-lms",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "school-lms",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#5865f2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.school.lms"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5865f2"
      },
      "package": "com.school.lms"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5865f2",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3000/api/v1",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}
